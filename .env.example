# Copy this file to `.env.local` for local development.
# `.env.local` is gitignored. DO NOT commit a populated env file.
#
# `config.py` reads `.env.local` (not `.env`) and ALSO validates that the DB URL
# points at a local host. Cloud Supabase URLs are rejected by config — see
# docs/dev/local-supabase.md.

# Local Supabase Postgres (default port 54322 when running `supabase start`).
SUPABASE_DB_URL_ASYNC=postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/postgres

# Outbound request identification — appears in the User-Agent for every scrape.
# Compliance requirement (see CLAUDE.md "Scraping rules").
USER_AGENT_EMAIL=you@example.com

# Optional in dev.
# SENTRY_DSN=

# Deferred — do NOT populate without explicit approval per
# docs/decisions/0001-initial-scope-clarifications.md.
# ANTHROPIC_API_KEY=
# OUTSCRAPER_API_KEY=
# GOOGLE_GEOCODING_API_KEY=
